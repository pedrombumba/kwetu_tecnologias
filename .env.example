# Environment Variables
# Copy this file to .env.local and fill in actual values

# Database (when implemented)
# DATABASE_URL=your_database_url_here

# Email Service (when implemented)
# RESEND_API_KEY=your_resend_api_key_here
# SENDGRID_API_KEY=your_sendgrid_api_key_here

# Analytics (when implemented)
# NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=your_ga_id_here
# NEXT_PUBLIC_MIXPANEL_TOKEN=your_mixpanel_token_here

# Authentication (when implemented with NextAuth)
# NEXTAUTH_SECRET=your_secret_key_here
# NEXTAUTH_URL=http://localhost:3000

# Payment Gateway (Stripe, when implemented)
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_pk_here
# STRIPE_SECRET_KEY=your_stripe_sk_here

# Public APIs
# NEXT_PUBLIC_API_URL=http://localhost:3000/api

# Feature Flags (when implemented)
# NEXT_PUBLIC_ENABLE_BLOG=true
# NEXT_PUBLIC_ENABLE_ACADEMIA=true
